{
  "name": "@shorts/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@shorts/shared-types": "workspace:*",
    "express": "4.19.2",
    "zod": "3.23.8",
    "@prisma/client": "5.17.0"
  },
  "devDependencies": {
    "@shorts/eslint-config": "workspace:*",
    "@shorts/tsconfig": "workspace:*",
    "@types/express": "4.17.21",
    "@types/node": "20.14.12",
    "eslint": "9.7.0",
    "tsx": "4.16.2",
    "typescript": "5.5.4",
    "prisma": "5.17.0"
  },
  "prisma": {
    "seed": "tsx src/db/seed.ts"
  }
}
