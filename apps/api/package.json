    "zod": "3.23.8"
  },
  "devDependencies": {
    "@shorts/eslint-config": "workspace:*",
    "@shorts/tsconfig": "workspace:*",
    "@types/express": "4.17.21",
    "@types/node": "20.14.12",
    "eslint": "9.7.0",
    "tsx": "4.16.2",
    "typescript": "5.5.4"
  }
}
